{
  "name": "rez-intent-graph",
  "version": "0.2.0",
  "description": "ReZ Mind - AI-powered commerce intelligence platform with autonomous agents for intent tracking, dormant revival, and personalized nudges",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/server/server.js",
    "lint": "eslint src --ext .ts",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch",
    "test:unit": "NODE_OPTIONS='--experimental-vm-modules' jest src/__tests__/unit",
    "test:integration": "NODE_OPTIONS='--experimental-vm-modules' jest src/__tests__/integration",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
    "test:circuit-breaker": "NODE_OPTIONS='--experimental-vm-modules' jest src/__tests__/unit/middleware/circuitBreaker",
    "test:cache": "NODE_OPTIONS='--experimental-vm-modules' jest src/__tests__/unit/middleware/cache",
    "test:mongodb": "NODE_OPTIONS='--experimental-vm-modules' jest src/__tests__/unit/database/mongodb",
    "test:intent-service": "NODE_OPTIONS='--experimental-vm-modules' jest src/__tests__/unit/services/IntentCaptureService",
    "test:agents": "tsx src/test/agent-test.ts",
    "test:smoke": "tsx src/test/smoke-test.ts",
    "test:server": "tsx src/server/server.ts",
    "test:agent-server": "tsx src/server/agent-server.ts"
  },
  "dependencies": {
    "@sentry/node": "^7.88.0",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.8.3",
    "winston": "^3.11.0",
    "ws": "^8.20.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.9.0",
    "@types/ws": "^8.18.1",
    "jest": "^29.7.0",
    "jest-mock-extended": "^4.0.1",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  }
}
