# ── ReZ Mind Intent Graph - Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in the values

# ── Environment ────────────────────────────────────────────────────────────────
# Set to 'production' for production deployments
NODE_ENV=development

# ── Server Ports ────────────────────────────────────────────────────────────────
PORT=3001
AGENT_PORT=3005

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Connection string for MongoDB Atlas
MONGODB_URI=mongodb+srv://work_db_user:<YOUR_PASSWORD>@rez-intent-graph.a8ilqgi.mongodb.net/?appName=rez-intent-graph

# ── Redis (Optional) ───────────────────────────────────────────────────────────
# For distributed shared memory across agent instances
# Required for production: enables Redis caching layer for fast intent reads
# If not set, falls back to in-memory store
REDIS_URL=redis://localhost:6379

# ── OpenAI Embeddings (Optional) ───────────────────────────────────────────
# For vector similarity search
# If not set, uses hash-based embeddings (less accurate but works offline)
OPENAI_API_KEY=

# ── Authentication ─────────────────────────────────────────────────────────────
# Internal service token for server-to-server auth
# Must match across all ReZ ecosystem services
INTERNAL_SERVICE_TOKEN=change-me-to-a-secure-random-string

# Merchant API key (used alongside x-merchant-token header)
MERCHANT_API_KEY=

# ── Webhook Security ───────────────────────────────────────────────────────────
# Secret for verifying incoming webhooks
# Set this in production to prevent unauthorized webhook calls
INTENT_WEBHOOK_SECRET=change-me-to-a-secure-random-string

# ── Cron Security ──────────────────────────────────────────────────────────────
# Secret for triggering cron jobs via API
# Only requests with matching x-cron-secret header will be accepted
INTENT_CRON_SECRET=change-me-to-a-secure-random-string

# ── CORS (Optional) ────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# If not set, defaults to restrictive localhost-only for dev
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Autonomous Mode ────────────────────────────────────────────────────────────
# WARNING: Setting this to true auto-enables dangerous mode on server startup
# Only set to true if you understand the security implications
REZ_DANGEROUS_MODE=false

# ── Phase 2: Dormant Intent Revival ──────────────────────────────────────────
# Enable/disable the dormant intent cron job (runs daily)
# Set to 'false' to disable if running on a separate cron worker
ENABLE_DORMANT_CRON=true

# ── Phase 3: Agent OS ────────────────────────────────────────────────────────
# Enable/disable the agent swarm
# Set to 'true' to enable autonomous agent mode
ENABLE_AGENTS=false

# ── Logging ────────────────────────────────────────────────────────────────────
# Set to 'debug' for verbose logging in development
LOG_LEVEL=info

# ── External Service URLs ───────────────────────────────────────────────────────
# SOURCE OF TRUTH: src/config/services.ts
# Override individual services here if they differ from defaults

# Core ReZ Services
WALLET_SERVICE_URL=https://rez-wallet-service-36vo.onrender.com
MONOLITH_URL=https://rez-backend-8dfu.onrender.com
ORDER_SERVICE_URL=https://rez-order-service-hz18.onrender.com
PAYMENT_SERVICE_URL=https://rez-payment-service.onrender.com
MERCHANT_SERVICE_URL=https://rez-merchant-service-n3q2.onrender.com

# Messaging & Notifications
NOTIFICATION_SERVICE_URL=https://rez-notification-events-mwdz.onrender.com

# Authentication
AUTH_SERVICE_URL=https://rez-auth-service.onrender.com

# Product & Search
CATALOG_SERVICE_URL=https://rez-catalog-service-1.onrender.com
SEARCH_SERVICE_URL=https://rez-search-service.onrender.com

# Growth & Marketing
MARKETING_SERVICE_URL=https://rez-marketing-service.onrender.com
GAMIFICATION_SERVICE_URL=https://rez-gamification-service-3b5d.onrender.com
ADS_SERVICE_URL=https://rez-ads-service.onrender.com

# Hotel & PMS
PMS_SERVICE_URL=https://rez-pms-service.onrender.com

# Analytics
ANALYTICS_SERVICE_URL=https://analytics-events-37yy.onrender.com
